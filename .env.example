# ─────────────────────────────────────────────────────────────────────────
# Client (Vite) — statically baked into the bundle at build time.
# ─────────────────────────────────────────────────────────────────────────
# Native (Capacitor / iOS / Android) builds MUST set this to the deployed API
# origin, because the bundle is served from capacitor://localhost with no
# backend attached. Example:
#   VITE_API_BASE_URL=https://neureuther.example.com
# Leave it UNSET (blank) for web builds so all /api requests stay same-origin.
VITE_API_BASE_URL=

# ─────────────────────────────────────────────────────────────────────────
# Server (Nitro) — never shipped to the browser. Set these on the host
# (e.g. Vercel project env vars), not in the client bundle.
# ─────────────────────────────────────────────────────────────────────────
# Neon Postgres connection string.
DATABASE_URL=

# 4-digit app-level PIN checked by /api/verify-app-pin.
APP_PIN=

# Base URL of the Neon Auth service used by server/utils/session.ts.
NEON_AUTH_BASE_URL=
